# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/sego_basman_db?connection_limit=10"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# JWT — WAJIB diganti dengan secret random minimal 64 karakter
JWT_SECRET="ganti-dengan-secret-random-minimal-64-karakter"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_SECRET="ganti-dengan-refresh-secret-yang-berbeda"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3001
NODE_ENV="development"
APP_URL="http://localhost:3001"

# CORS — URL frontend
FRONTEND_URL="http://localhost:3000"

# Bcrypt
BCRYPT_ROUNDS=12
